{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true
  },

  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/test-app-results/**",
    "**/test-app-results/**",
    "**/eval-view",
    "**/eval-view/**/*"
  ]
}
