{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "globals": {
    "Diff": "readonly"
  },
  "rules": {
    "no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^.*$"
    }],
    "eslint(no-undef)": "error",
    "no-undef": "error"
  }
}
