---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const multimedia = await getCollection('multimedia');
---
<Layout title="Multimedia">
    <div class="max-w-3xl mx-auto px-4 py-8 md:py-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 pb-2 border-b-2">Multimedia</h1>
        <div class="prose max-w-none">
            <p>Watch our latest multimedia content.</p>
            <ul>
                {multimedia.map(item => (
                    <li>
                        <a href={`/multimedia/${item.slug}`}>{item.data.title}</a>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</Layout>